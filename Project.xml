<?xml version="1.0" encoding="utf-8"?>
<project>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!--                        APPLICATION SETTINGS                           -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->

	<!-- Default title used on all platforms unless overridden below -->
	<app title="Friday Night Funkin': Moon Extended"
	     file="MoonExtended"
	     packageName="com.teammoon.moonextended"
	     package="com.teammoon.moonextended"
	     main="Main"
	     version="0.2.8"
	     company="TeamMoon" />

	<!-- Android-specific title override -->
	<app title="FNF: Moon Extended" if="android" />

	<!-- Nintendo Switch export — unique Application ID -->
	<set name="APP_ID" value="0x0100f6c013bbc000" />

	<!-- Stable Lua dynamic library linking — disable only if linking issues arise -->
	<haxedef name="LINC_LUA_RELATIVE_DYNAMIC_LIB" />

	<!-- Flash preloader (accurate only when SWF is embedded in HTML) -->
	<!-- <app preloader="Preloader" resizable="true" /> -->
	<app preloader="flixel.system.FlxPreloader" />

	<!-- Minimum SWF version: 11.8 without FLX_NO_GAMEPAD, 11.2 without FLX_NO_NATIVE_CURSOR -->
	<set name="SWF_VERSION" value="11.8" />


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!--                       ENGINE FEATURE FLAGS                            -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->

	<!-- Mod folder support (desktop, mobile, and web via Emscripten) -->
	<define name="MODS_ALLOWED"        if="desktop || mobile || emscripten" />

	<!-- HScript runtime scripting support -->
	<define name="HSCRIPT_ALLOWED"     if="desktop || mobile || web" />

	<!-- Lua scripting support (not supported on HashLink) -->
	<define name="LUA_ALLOWED"         if="desktop || mobile" unless="hl" />

	<!-- In-game achievements system -->
	<define name="ACHIEVEMENTS_ALLOWED" />

	<!-- Discord Rich Presence (desktop only, not HashLink) -->
	<define name="DISCORD_ALLOWED"     if="desktop" unless="hl" />

	<!-- Remove PSYCH_WATERMARKS to strip dev credits from the title screen -->
	<define name="PSYCH_WATERMARKS" />

	<!-- Video cutscene support via hxCodec/hxvlc — excluded on 32-bit, HashLink, and RPi builds -->
	<define name="VIDEOS_ALLOWED"      if="desktop || mobile" unless="32bits || hl || NOVIDEO || rpi" />

	<!-- GLSL shader support (not available on Flash) -->
	<define name="CUSTOM_SHADERS_ALLOWED" unless="flash" />

	<!-- Auto-update check on official/release builds (not on iOS) -->
	<define name="CHECK_FOR_UPDATES"   if="officialBuild" unless="ios" />


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!--                          WINDOW SETTINGS                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->

	<!-- Base window config for all targets -->
	<window width="1280" height="720" fps="60" background="#000000"
	        hardware="true" vsync="false" />

	<!-- HTML5: allow the canvas to resize with the browser window -->
	<window if="html5" resizable="true" />

	<!-- Desktop: landscape, windowed by default, user-resizable -->
	<window if="desktop" orientation="landscape" fullscreen="false"
	        resizable="true" vsync="false" />

	<!-- Mobile: forced fullscreen landscape with high-DPI and shader support -->
	<window if="mobile" orientation="landscape" fullscreen="true"
	        resizable="false" allow-shaders="true" require-shaders="true"
	        allow-high-dpi="true" />

	<!-- Nintendo Switch: fullscreen, let the OS decide resolution -->
	<window if="switch" orientation="landscape" fullscreen="true"
	        width="0" height="0" resizable="true" />


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!--                         BUILD DIRECTORIES                             -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->

	<set name="BUILD_DIR" value="export/debug"   if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />
	<set name="BUILD_DIR" value="export/32bit"   if="32bits" />
	<set name="BUILD_DIR" value="export/rpi"     if="rpi" />

	<classpath name="source" />


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!--                        ASSETS & PRELOADING                            -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->

	<!-- Preload everything on non-web targets for smoother runtime performance -->
	<define name="PRELOAD_ALL"    unless="web" />
	<define name="NO_PRELOAD_ALL" unless="PRELOAD_ALL" />

	<!-- Core fonts (always preloaded) -->
	<assets path="assets/fonts" />

	<!-- Shared assets — exclude the format not used by the current target -->
	<assets path="assets/shared" exclude="*.ogg" if="web" />
	<assets path="assets/shared" exclude="*.mp3" unless="web" />

	<!-- Video assets, only when video support is enabled -->
	<assets path="assets/videos" library="videos" if="VIDEOS_ALLOWED" />

	<!-- Song audio -->
	<assets path="assets/songs" library="songs" exclude="*.ogg" if="web" />
	<assets path="assets/songs" library="songs" exclude="*.mp3" unless="web" />

	<!-- Week-specific assets (remapped to "assets" at runtime) -->
	<assets path="assets/week_assets" library="week_assets" rename="assets" exclude="*.ogg" if="web" />
	<assets path="assets/week_assets" library="week_assets" rename="assets" exclude="*.mp3" unless="web" />

	<!-- Optional secret/easter-egg assets for the title screen -->
	<section if="TITLE_SCREEN_EASTER_EGG">
		<assets path="assets/secrets" rename="assets/shared" exclude="*.ogg" if="web" />
		<assets path="assets/secrets" rename="assets/shared" exclude="*.mp3" unless="web" />
	</section>

	<!-- Always preload videos to avoid hitches during cutscenes -->
	<library name="videos"      preload="true" if="VIDEOS_ALLOWED" />

	<!-- Preload songs and week assets on native targets -->
	<section if="PRELOAD_ALL">
		<library name="songs"       preload="true" />
		<library name="week_assets" preload="true" />
	</section>

	<!-- Lazy-load on web to keep initial bundle size small -->
	<section if="NO_PRELOAD_ALL">
		<library name="songs"       preload="false" />
		<library name="week_assets" preload="false" />
	</section>

	<!-- Embed example mods folder as the default "mods" directory -->
	<section if="MODS_ALLOWED">
		<assets path="example_mods" rename="mods" embed="false" />
	</section>

	<!-- Readme file shipped alongside the executable on desktop -->
	<assets path="art/readme.txt" rename="do NOT readme.txt" unless="mobile" />


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!--                            HAXE LIBRARIES                             -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->

	<!-- HaxeFlixel core -->
	<haxelib name="flixel" />
	<haxelib name="flixel-ui" />
	<haxelib name="flixel-addons" />

	<!-- Lua scripting runtime -->
	<haxelib name="linc_luajit"         if="LUA_ALLOWED" />

	<!-- HScript runtime -->
	<haxelib name="SScript"             if="HSCRIPT_ALLOWED" />

	<!-- Video playback: hxCodec for most targets, hxvlc for iOS -->
	<haxelib name="hxCodec"             if="VIDEOS_ALLOWED" unless="ios" />
	<haxelib name="hxvlc"               if="VIDEOS_ALLOWED ios" />

	<!-- Discord Rich Presence -->
	<haxelib name="hxdiscord_rpc"       if="DISCORD_ALLOWED" />

	<!-- Texture atlas / spine-like animation support -->
	<haxelib name="flxanimate"          unless="html5" />

	<!-- Lenient JSON parser (tolerates trailing commas and comments) -->
	<haxelib name="tjson" />

	<!-- Android-specific native utilities (file picker, permissions, etc.) -->
	<haxelib name="extension-androidtools" if="android" />

	<!-- HXCPP debug server — enables VS Code breakpoint debugging on debug builds -->
	<haxelib name="hxcpp-debug-server"  if="debug" />


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!--                           HAXE DEFINES                                -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->

	<!-- Disable Discord's background IO thread to reduce threading overhead -->
	<haxedef name="DISCORD_DISABLE_IO_THREAD" if="hxdiscord_rpc" />

	<!-- Precompiled headers can break some Linux toolchains — keep them off -->
	<haxedef name="NO_PRECOMPILED_HEADERS" if="linux" />

	<!-- ── Flixel feature toggles ──────────────────────────────────────────── -->

	<!-- Disable the focus-lost overlay (cleaner UX, especially on mobile) -->
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />

	<!-- Uncomment to enable Flixel's built-in replay recording system -->
	<!-- <haxedef name="FLX_RECORD" /> -->

	<!-- Uncomment to disable right/middle mouse buttons -->
	<!-- <haxedef name="FLX_NO_MOUSE_ADVANCED" /> -->

	<!-- Platform-specific input optimisations (uncomment if needed) -->
	<!-- <haxedef name="FLX_NO_MOUSE"    if="mobile" /> -->
	<!-- <haxedef name="FLX_NO_KEYBOARD" if="mobile" /> -->
	<!-- <haxedef name="FLX_NO_TOUCH"    if="desktop" /> -->
	<!-- <haxedef name="FLX_NO_GAMEPAD" /> -->

	<!-- Uncomment to strip the Flixel sound tray entirely -->
	<!-- <haxedef name="FLX_NO_SOUND_TRAY" /> -->

	<!-- Disable Flixel's built-in debugger on release builds (auto-set, explicit for clarity) -->
	<haxedef name="FLX_NO_DEBUG" unless="debug" />

	<!-- ── hxCodec / VLC debug output ──────────────────────────────────────── -->
	<haxedef name="HXC_DEBUG_TRACE"    if="debug hxCodec" />
	<haxedef name="HXC_LIBVLC_LOGGING" if="debug hxCodec" />

	<!-- ── HXCPP runtime safety & stack traces ─────────────────────────────── -->

	<!-- Null pointer check — catches NPEs early; disable in final release for speed -->
	<haxedef name="HXCPP_CHECK_POINTER" />

	<!-- Include line numbers and full stack traces in crash reports -->
	<haxedef name="HXCPP_STACK_LINE"  />
	<haxedef name="HXCPP_STACK_TRACE" />

	<!-- ── HXCPP performance optimisations ─────────────────────────────────── -->

	<!-- Generational GC: reduces GC pause times significantly on large heaps -->
	<haxedef name="HXCPP_GC_GENERATIONAL" unless="debug" />

	<!-- Aggressive compiler optimisations for release builds -->
	<haxedef name="HXCPP_OPTIMIZE_FOR_SPEED" unless="debug" />

	<!-- Nape physics release optimisations (no effect if Nape isn't used) -->
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />

	<!-- ── Miscellaneous ───────────────────────────────────────────────────── -->

	<!-- Suppress deprecation warnings from third-party libraries -->
	<haxedef name="no-deprecation-warnings" />

	<!-- Disable inlining on HTML5 to keep JavaScript output debuggable -->
	<haxedef name="no-inline" if="html5" />

	<!-- Macro compatibility shims -->
	<haxeflag name="--macro" value="allowPackage('flash')" />
	<haxeflag name="--macro" value="include('my.pack')" />


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!--                         ANDROID SETTINGS                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->

	<section if="android">

		<!-- Release signing — keystore credentials -->
		<!-- ⚠ WARNING: Do NOT commit real credentials to a public repository.  -->
		<!--   Consider using environment variables or a secrets manager instead. -->
		<certificate path="key.keystore"
		             password="nullfunni"
		             alias="null"
		             alias-password="nullfunni"
		             unless="debug" />

		<!-- SDK version targeting -->
		<!-- Minimum SDK 21 = Android 5.0 Lollipop (wide device coverage)       -->
		<android minimum-sdk-version="21" />

		<!-- Target SDK 33 = Android 13 (required for Play Store compliance)      -->
		<!-- Use 28 only when EXTERNAL/MEDIA storage APIs need legacy behaviour   -->
		<android target-sdk-version="33" unless="EXTERNAL || MEDIA" />
		<android target-sdk-version="28" if="EXTERNAL || MEDIA" />  <!-- Android 11+ storage workaround -->

		<!-- Gradle build tools version — keep in sync with your local SDK install -->
		<android build-tools-version="34.0.0" />

		<!-- Enable large heap to reduce OOM crashes on asset-heavy songs -->
		<config:android large-heap="true" />

	</section>


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!--                      ICONS & CUSTOM ASSETS                            -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->

	<!-- Linux taskbar icon -->
	<assets path="art/icon16.png" rename="icon.png" if="linux" />

	<!-- Multi-resolution icons for all platforms -->
	<icon path="art/icon16.png" size="16" />
	<icon path="art/icon32.png" size="32" />
	<icon path="art/icon64.png" size="64" />
	<icon path="art/iconOG.png" />

</project>
